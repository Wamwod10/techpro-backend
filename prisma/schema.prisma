generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  cashier
}

enum PaymentMethod {
  cash
  card
  transfer
}

enum SaleStatus {
  active
  closed
}

enum ShiftStatus {
  open
  closed
}

enum SupplierTransactionType {
  inventory
  payment
  adjustment
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  email     String?  @unique
  password  String
  role      Role     @default(cashier)
  storeId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  store        Store?        @relation(fields: [storeId], references: [id])
  sales        Sale[]
  returns      Return[]
  shiftsOpened Shift[]       @relation("ShiftOpenedBy")
  shiftsClosed Shift[]       @relation("ShiftClosedBy")
  activityLogs ActivityLog[]

  @@index([storeId])
}

model Store {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users                User[]
  products             Product[]
  sales                Sale[]
  saleItems            SaleItem[]
  salesDays            SalesDay[]
  returns              Return[]
  suppliers            Supplier[]
  supplierTransactions SupplierTransaction[]
  expenses             Expense[]
  shifts               Shift[]
  activityLogs         ActivityLog[]
  telegramSettings     TelegramSettings?
}

model Product {
  id            String   @id @default(cuid())
  storeId       String
  name          String
  sku           String?
  barcode       String?
  category      String?
  quantity      Int      @default(0)
  costPrice     Float    @default(0)
  sellPrice     Float    @default(0)
  price         Float?
  stock         Int?
  supplier      String?
  returnDays    String?
  paymentStatus String?
  debtAmount    Float    @default(0)
  supplierPhone String?
  date          String?
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  saleItems SaleItem[]
  returns   Return[]
  store     Store      @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([storeId, isDeleted, createdAt])
  @@index([isDeleted])
  @@unique([storeId, sku])
  @@unique([storeId, barcode])
}

model Sale {
  id            String        @id @default(cuid())
  storeId       String
  dateISO       String
  date          String
  time          String
  total         Float
  saleSubtotal  Float         @default(0)
  saleDiscountTotal Float     @default(0)
  saleTotal     Float         @default(0)
  returnedTotal Float         @default(0)
  paymentMethod PaymentMethod
  status        SaleStatus    @default(active)
  sellerId      String?
  shiftId       String?
  sellerName    String?
  sellerRole    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt

  store   Store      @relation(fields: [storeId], references: [id])
  seller  User?      @relation(fields: [sellerId], references: [id])
  shift   Shift?     @relation(fields: [shiftId], references: [id])
  items   SaleItem[]
  returns Return[]

  @@index([storeId, status, dateISO])
  @@index([storeId, status, dateISO, createdAt])
  @@index([sellerId])
  @@index([shiftId])
}

model SaleItem {
  id           String  @id @default(cuid())
  storeId      String
  saleId       String
  productId    String
  name         String
  sku          String?
  quantity     Int
  price        Float
  originalPrice Float  @default(0)
  finalPrice    Float  @default(0)
  itemDiscountPercent Float @default(0)
  itemDiscountAmount  Float @default(0)
  costPrice    Float   @default(0)
  returnedQty  Int     @default(0)
  returnStatus String  @default("none")

  store   Store   @relation(fields: [storeId], references: [id])
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  returns Return[]

  @@index([storeId])
}

model SalesDay {
  id            String   @id @default(cuid())
  storeId       String
  dateISO       String
  date          String
  total         Float    @default(0)
  cash          Float    @default(0)
  card          Float    @default(0)
  transfer      Float    @default(0)
  returnedTotal Float    @default(0)
  count         Int      @default(0)
  closedBy      String?
  autoClosed    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, dateISO])
  @@index([storeId, dateISO])
}

model Return {
  id            String        @id @default(cuid())
  storeId       String
  saleId        String
  saleItemId    String?
  productId     String?
  productName   String
  sku           String?
  quantity      Int
  amount        Float
  reason        String
  paymentMethod PaymentMethod?
  sellerId      String?
  sellerName    String?
  sellerRole    String?
  date          String
  dateISO       String
  time          String
  createdAt     DateTime      @default(now())

  store    Store     @relation(fields: [storeId], references: [id])
  sale     Sale      @relation(fields: [saleId], references: [id])
  saleItem SaleItem? @relation(fields: [saleItemId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])
  seller   User?     @relation(fields: [sellerId], references: [id])

  @@index([storeId, dateISO])
  @@index([storeId, createdAt])
  @@index([saleId])
}

model Supplier {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  phone        String?
  address      String?
  notes        String?
  debt         Float    @default(0)
  paid         Float    @default(0)
  deadline     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  transactions SupplierTransaction[]
  store        Store                 @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([storeId, createdAt])
}

model SupplierTransaction {
  id          String                  @id @default(cuid())
  storeId     String
  supplierId  String
  type        SupplierTransactionType @default(inventory)
  status      String?
  productName String?
  amount      Float
  phone       String?
  date        String
  time        String
  note        String?
  createdAt   DateTime                @default(now())

  store    Store    @relation(fields: [storeId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([storeId, supplierId, createdAt])
}

model Expense {
  id        String   @id @default(cuid())
  storeId   String
  title     String
  category  String   @default("Boshqa")
  amount    Float
  note      String?
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([storeId, createdAt])
}

model Shift {
  id             String      @id @default(cuid())
  storeId        String
  cashierName    String
  openedById     String?
  openedByName   String?
  closedById     String?
  closedByName   String?
  openingCash    Float
  closingCash    Float?
  cashDifference Float?
  totalSales     Float       @default(0)
  cashSales      Float       @default(0)
  cardSales      Float       @default(0)
  transferSales  Float       @default(0)
  transactions   Int         @default(0)
  openedAt       String
  openedAtISO    DateTime
  closedAt       String?
  closedAtISO    DateTime?
  duration       String?
  date           String
  status         ShiftStatus @default(open)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt

  store    Store @relation(fields: [storeId], references: [id])
  openedBy User? @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  closedBy User? @relation("ShiftClosedBy", fields: [closedById], references: [id])
  sales    Sale[]

  @@index([storeId, status])
  @@index([storeId, status, closedAtISO])
  @@index([closedAtISO])
}

model ActivityLog {
  id          String   @id @default(cuid())
  storeId     String
  type        String   @default("general")
  title       String
  description String?
  userId      String?
  userName    String
  userRole    String
  date        String
  time        String
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@index([storeId, createdAt])
}

model TelegramSettings {
  id          String   @id @default(cuid())
  storeId     String   @unique
  botToken    String?
  chatId      String?
  newSale     Boolean  @default(true)
  dailyReport Boolean  @default(true)
  returns     Boolean  @default(true)
  lowStock    Boolean  @default(true)
  outOfStock  Boolean  @default(true)
  shiftOpen   Boolean  @default(true)
  shiftClose  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  store Store @relation(fields: [storeId], references: [id])
}
